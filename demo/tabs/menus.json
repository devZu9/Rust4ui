{
  "type": "Tab",
  "id": "menus",
  "title": "{{tab.menus}}",
  "children": [
    {
      "type": "ScrollArea",
      "axis": "vertical",
      "max_height": 600,
      "children": [
        {
          "type": "Column",
          "gap": 12,
          "padding": 16,
          "children": [
            {
              "type": "Label",
              "text": "Меню",
              "size": 20,
              "bold": true
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Пример MenuBar (Файл / Правка / Помощь):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "MenuBar",
	      "background": ["$rust", 1], 
	      "background_hover": ["$yellow", 1], 
	      "padding": 5,
 	      "padding_children": 5,
	      "margin_children": [10, 0],
	      "color_children": "$cyan",
	      "gap": 5, 
              "children": [
                {
                  "type": "Menu",
                   "text": "{{menu.file}}",
                  "children": [
                    { 
		    "type": "MenuItem", 
		    "icon": "plus", 
		    "text": "{{menu.new}}", 
		    "action": "click", 
		    "target": "menu_new" 
		    },
                    { "type": "MenuItem", "icon": "folder-simple", "text": "{{menu.open}}", "action": "click", "target": "menu_open" },
                    { "type": "Separator" },
                    { "type": "MenuItem", "icon": "download-simple", "text": "{{menu.export}}", "action": "click", "target": "menu_export" },
                    { "type": "Separator" },
                    { "type": "MenuItem", "icon": "x", "text": "{{menu.exit}}", "action": "click", "target": "menu_exit" }
                  ]
                },
                {
                  "type": "Menu",
                  "text": "{{menu.help}}",
                  "children": [
                    { "type": "MenuItem", "icon": "question", "text": "{{menu.help}}", "action": "click", "target": "menu_about" },
                    { "type": "Separator" },
                    { "type": "MenuItem", "icon": "question", "text": "{{menu.about}}", "action": "click", "target": "menu_about" }
                  ]
                },
                {
                  "type": "Menu",
                  "text": "{{menu.edit}}",
                  "children": [
                    { "type": "MenuItem", "icon": "arrow-counter-clockwise", "text": "{{menu.undo}}", "action": "click", "target": "menu_undo" },
                    { "type": "MenuItem", "icon": "arrow-clockwise", "text": "{{menu.redo}}", "action": "click", "target": "menu_redo" },
                    { "type": "Separator" },
                    { "type": "MenuItem", "icon": "gear-six", "text": "{{chk.gpu}}", "action": "click", "target": "menu_gpu" }
                  ]
                }

              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Горизонтальная панель иконок (IconBar horizontal):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "IconBar",
              "direction": "horizontal",
              "children": [
                { "type": "IconButton", "icon": "floppy-disk", "action": "click", "target": "icon_save", "tooltip": "{{tip.save_title}}" },
                { "type": "IconButton", "icon": "copy-simple", "action": "click", "target": "icon_copy", "tooltip": "Копировать" },
                { "type": "IconButton", "icon": "clipboard-text", "action": "click", "target": "icon_paste", "tooltip": "Вставить" },
                { "type": "IconButton", "icon": "gear-six", "action": "click", "target": "icon_settings", "tooltip": "Настройки" },
                { "type": "IconButton", "icon": "question", "action": "click", "target": "icon_help", "tooltip": "{{tooltip.hyperlink}}" }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Вертикальная панель иконок (IconBar vertical):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Row",
              "gap": 8,
              "children": [
                {
                  "type": "IconBar",
                  "direction": "vertical",
                  "children": [
                    { "type": "IconButton", "icon": "house-simple", "action": "click", "target": "icon_home", "tooltip": "Главная" },
                    { "type": "IconButton", "icon": "user", "action": "click", "target": "icon_user", "tooltip": "Пользователь" },
                    { "type": "IconButton", "icon": "folder-simple", "action": "click", "target": "icon_folder", "tooltip": "Папка" },
                    { "type": "IconButton", "icon": "download-simple", "action": "click", "target": "icon_download", "tooltip": "Скачать" },
                    { "type": "IconButton", "icon": "upload-simple", "action": "click", "target": "icon_upload", "tooltip": "Загрузить" }
                  ]
                }
              ]
          }
          ]
        }
      ]
    }
  ]
}
