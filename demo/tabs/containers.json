{
  "type": "Tab",
  "id": "containers",
  "title": "{{tab.containers}}",
  "children": [
    {
      "type": "ScrollArea",
      "axis": "vertical",
      "max_height": 600,
      "children": [
        {
          "type": "Column",
          "gap": 12,
          "padding": 16,
          "children": [
            {
              "type": "Label",
              "text": "{{label.containers_title}}",
              "size": 20,
              "bold": true
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "{{label.panel_title}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Panel",
              "fill": "#1A1D23",
              "rounding": 8,
              "padding": 12,
              "stroke_width": 1,
              "stroke_color": "#333333",
              "children": [
                {
                  "type": "Label",
                  "text": "{{label.panel_card_title}}",
                  "size": 14,
                  "bold": true
                },
                {
                  "type": "Label",
                  "text": "{{label.panel_desc}}",
                  "size": 12,
                  "color": "#888888"
                }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "{{label.row_wrap}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Row",
              "gap": 6,
              "wrap": true,
              "children": [
                {
                  "type": "Button",
                  "text": "{{btn.item}} 1",
                  "action": "click",
                  "target": "item_1",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 2",
                  "action": "click",
                  "target": "item_2",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 3",
                  "action": "click",
                  "target": "item_3",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 4",
                  "action": "click",
                  "target": "item_4",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 5",
                  "action": "click",
                  "target": "item_5",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 6",
                  "action": "click",
                  "target": "item_6",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 7",
                  "action": "click",
                  "target": "item_7",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 8",
                  "action": "click",
                  "target": "item_8",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 9",
                  "action": "click",
                  "target": "item_9",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                },
                {
                  "type": "Button",
                  "text": "{{btn.item}} 10",
                  "action": "click",
                  "target": "item_10",
                  "fill": "#2A2A33",
                  "rounding": 12,
                  "min_width": 70
                }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Колонки 50/50 (Row columns=2):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Row",
              "columns": 2,
              "children": [
                {
                  "type": "Panel",
                  "fill": "#1A1D23",
                  "rounding": 8,
                  "padding": 12,
                  "children": [
                    {
                      "type": "Label",
                      "text": "Левая панель (50%)",
                      "size": 14,
                      "bold": true
                    },
                    {
                      "type": "Label",
                      "text": "Сюда можно поместить любой контент: поля, кнопки, списки.",
                      "size": 12,
                      "color": "#888888"
                    }
                  ]
                },
                {
                  "type": "Panel",
                  "fill": "#1C1E24",
                  "rounding": 8,
                  "padding": 12,
                  "children": [
                    {
                      "type": "Label",
                      "text": "Правая панель (50%)",
                      "size": 14,
                      "bold": true
                    },
                    {
                      "type": "TextField",
                      "binding": "name",
                      "width": 140
                    },
                    {
                      "type": "Button",
                      "text": "{{btn.greeting}}",
                      "action": "greeting",
                      "min_width": 120
                    }
                  ]
                }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Таблицы (без сетки / с сеткой):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Row",
              "columns": 2,
              "children": [
                {
                  "type": "Grid",
                  "columns": 3,
                  "spacing_x": 12,
                  "spacing_y": 4,
                  "striped": false,
                  "children": [
                    {"type": "Label", "text": "{{grid.col_a}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.col_b}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.col_c}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.proj_a}}"},
                    {"type": "Label", "text": "{{grid.stat_a}}"},
                    {"type": "Label", "text": "{{grid.ver_a}}"},
                    {"type": "Label", "text": "{{grid.proj_b}}"},
                    {"type": "Label", "text": "{{grid.stat_b}}"},
                    {"type": "Label", "text": "{{grid.ver_b}}"}
                  ]
                },
                {
                  "type": "Grid",
                  "columns": 3,
                  "spacing_x": 12,
                  "spacing_y": 4,
                  "striped": true,
                  "children": [
                    {"type": "Label", "text": "{{grid.col_a}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.col_b}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.col_c}}", "bold": true, "color": "#66CCFF"},
                    {"type": "Label", "text": "{{grid.proj_a}}"},
                    {"type": "Label", "text": "{{grid.stat_a}}"},
                    {"type": "Label", "text": "{{grid.ver_a}}"},
                    {"type": "Label", "text": "{{grid.proj_b}}"},
                    {"type": "Label", "text": "{{grid.stat_b}}"},
                    {"type": "Label", "text": "{{grid.ver_b}}"},
                    {"type": "Label", "text": "{{grid.proj_c}}"},
                    {"type": "Label", "text": "{{grid.stat_c}}"},
                    {"type": "Label", "text": "{{grid.ver_c}}"},
                    {"type": "Label", "text": "Rust4ui"},
                    {"type": "Label", "text": "Готово"},
                    {"type": "Label", "text": "0.2"}
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}