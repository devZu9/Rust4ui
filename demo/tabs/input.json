{
  "type": "Tab",
  "id": "input",
  "title": "{{tab.input}}",
  "children": [
    {
      "type": "ScrollArea",
      "axis": "vertical",
      "max_height": 600,
      "children": [
        {
          "type": "Column",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "Label",
              "text": "{{label.input_title}}",
              "size": 20,
              "bold": true
            },
            {
              "type": "Label",
              "text": "{{label.text_input}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "TextField",
              "binding": "name",
              "hint": "{{hint.name}}",
              "width": 250
            },
            {
              "type": "Button",
              "icon": "pencil-simple",
              "text": "{{btn.greeting}}",
              "action": "greeting",
              "min_width": 180
            },
            {
              "type": "Separator",
              "space": 10
            },
            {
              "type": "Label",
              "text": "{{label.combo}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "ComboBox",
              "binding": "selected_device",
              "items": "device_list",
              "width": 300
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Row",
              "gap": 6,
              "align": "center",
              "children": [
                {
                  "type": "Label",
                  "text": "{{label.volume}}:",
                  "size": 14
                },
                {
                  "type": "Label",
                  "text": "{volume}%",
                  "size": 14,
                  "monospace": true,
                  "color": "#66CCFF"
                },
                {
                  "type": "Slider",
                  "binding": "volume",
                  "min": 0,
                  "max": 100,
                  "step": 1,
                  "width": 160
                }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "{{label.number_field}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "Row",
              "gap": 8,
              "align": "center",
              "children": [
                {
                  "type": "TextField",
                  "binding": "font_size",
                  "mode": "number",
                  "min": 8,
                  "max": 72,
                  "step": 2,
                  "decimals": 0,
                  "width": 120
                },
                {
                  "type": "Label",
                  "text": "{{label.font_size}}: {font_size}px",
                  "size": 13,
                  "monospace": true,
                  "color": "#AAAAAA"
                }
              ]
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "{{label.multiline}}",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "TextField",
              "binding": "description",
              "width": 400,
              "multiline": true
            },
            {
              "type": "Separator",
              "space": 10
            },
            {
              "type": "Label",
              "text": "{{label.status}}: {status_text}",
              "size": 13,
              "monospace": true,
              "color": "#AAAAAA"
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Label",
              "text": "Поле пароля (mode=password):",
              "size": 13,
              "color": "#888888"
            },
            {
              "type": "TextField",
              "binding": "password",
              "mode": "password",
              "width": 300
            },
            {
              "type": "Separator",
              "space": 8
            },
            {
              "type": "Row",
              "gap": 8,
              "children": [
                {
                  "type": "Button",
                  "icon": "check",
                  "text": "{{btn.apply}}",
                  "action": "apply",
                  "fill": "#3366CC",
                  "min_width": 120
                },
                {
                  "type": "Button",
                  "icon": "arrows-clockwise",
                  "text": "{{btn.reset}}",
                  "action": "reset",
                  "min_width": 120
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}