{
  "global": {
    "item_spacing_x": 8,
    "item_spacing_y": 10
  },
  "Label": {
    "color": "#CCCCCC",
    "size": 14,
    "margin": 0
  },
    "Button": {
    "fill": "#303030",
    "rounding": 25,
    "min_width": 190,
    "text_color": "#E0E0E0",
    "border_hover": [4, "#FF0", "dot", 4, 1],
    "border_click": [4, "#0FF", "dash", 5, 6],
    "padding": [15],
    "margin": 0
  },
  "IconButton": {
    "button_size": 20,
    "rounding": 15,
    "padding": [5, 25, 25, 5],
    "icon_size": 25,
  //  "margin": [3],
    "color": "#88F",  //  #88F
    "hover_color": "#FF0",   // yellow
    "click_color": "#0FF",   // cyan
    "border": [4, "#88F", "dot", 3, 1],
    "border_hover": [4, "#FF0", "dot", 4, 1],
    "border_click": [4, "#0FF", "dash", 5, 6]
  },
  "TextField": {
    "width": 200,
    "height": 48,
    "rounding": 40,
    "border": [5, "#303030", "dash", 9],
    "border_position": "center",
    "border_seg_cap": true,
    "padding": [15, 25],
    "background": "#000000",
    "border_hover": [4, "#FF0", "dot", 4, 1],
    "border_click": [4, "#0FF", "dash", 5, 6],
    "margin": 0
  },
  "ComboBox": {
    "width": 200,
    "height": 18,
    "rounding": 65,
    "padding": [15, 25],
    "margin": 0
  },
  "Slider": {
    "width": 250,
    "margin": 0
  },
  "Checkbox": {
    "margin": 0
  },
  "Separator": {
    "space": 6,
    "color": "#333333",
    "margin": 0
  },
  "Column": {
    "gap": 0,
    "padding": 0
  },
  "Row": {
    "gap": 0,
    "padding": 0,
    "align": "center"
  },
  "Tabs": {
    "gap": 4,
    "margin": 0,
    "tab_padding": 10
  },
  "Panel": {
    "fill": "#1A1D23",
    "rounding": 8,
    "padding": [5, 10, 15, 5],
    "border": [1, "#333333"]
  },
  "Window": {
    "default_width": 400,
    "default_height": 300,
    "resizable": true,
    "movable": true,
    "collapsible": true,
    "title_bar": true,
    "show_close": true,
    "constrain": true,
    "modal": false,
    "fill": "#1E1E24",
    "border": [1, "#33333A"],
    "padding": 8
  },
  "Hyperlink": {
    "color": "#66CCFF",
    "underline": true,
    "margin": 0
  },
  "Grid": {
    "spacing_x": 8,
    "spacing_y": 4
  },
  "ScrollArea": {
    "axis": "vertical"
  },
  "FileDrop": {
    "fill": "#1A1D23",
    "rounding": 8,
    "border": [1, "#333333"],

    "highlight_color": "#3366CC44",
    "padding": 16
  },
  "RadioGroup": {
    "margin": 0
  },
  "Spinner": {
    "color": "#66CCFF",
    "size": 24
  },
  "ColorPicker": {
    "width": 160
  },
  "MenuBar": {},
  "MenuItem": {},
  "SubMenu": {},
  "Notifications": {
    "width": 300
  },
  "Tray": {},
  "IconBar": {
    "fill": "#1C1C22",
    "border": 0
  },
  "Caption": {
    "color": "#888888",
    "size": 11,
    "margin": 0
  },
  "Indicator": {
    "size": 8
  },
  "StatusBar": {
    "height": 26,
    "fill": "#18181D",
    "border": [1, "#2A2A30"],
    "padding": 4
  }
}
