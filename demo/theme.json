{
  "global": {
    "item_spacing_x": 8,
    "item_spacing_y": 10
  },
  "Label": {
    "color": "#CCCCCC",
    "size": 14,
    "margin": 0
  },
    "Button": {
    "background": "#303030",
    "background_click": ["#FF0", 0],
    "background_hover": ["#FF0", 0],
    "rounding": 25,
    "min_width": 190,
 //   "color_text": "#E0E0E0",
    "color_icon": "#FF0",
    "shadow_content": [0.9, "under", "#000"],
    "shadow_icon_hover": [0.9, "under", "#F00"],
    "shadow_text_hover": [0.9, "under", "#020"],
    "shadow_background": 0,
    "border_hover": [4, "#FF0", 1, "dot", 4, 1],
    "shadow_border": [0.5, "over"],
    "border_click": [4, "#0FF", 1, "dash", 5, 6],
    "padding": [15],
    "margin": 0
  },
  "IconButton": {
    "button_size": 65,
    "rounding": 15,
 //   "padding": [5, 25, 25, 5],
 //   "padding_hover": [5, 7, 6, 5],
    "padding_click": [8, 20, 20, 8],
    "margin": [3],
//    "margin_hover": [10],
    "margin_click": [5],
    "rounding_click": 25,
 //   "rounding_hover": 10,
    "icon_size": 25,
    "icon_size_click": 20,
    "background": ["#000", 0],
    "background_click": ["#FF0", 0],
    "shadow_background": [0],
    "shadow_icon_hover": [0.4, "under", "#000", 1, 1],
    "shadow_border": [0.4],
    "shadow_icon": [0.7],
    "shadow_border_hover": [0.1],
    "color": "#88F",  //  
    "color_hover": "#F80",         // "#FF0",   // yellow
    "color_click": "#0FF",   // cyan
    /*
          #C74 - pitch
    */
    "border": [5, "#88F", 1, "dot", 3, 2],
    "border_hover": [5, "#F80", 0.01, "dot", 3, 2],
    "border_click": [4, "#0FF", 1, "dash", 5, 6]
  },
  "TextField": {
    "width": 200,
    "height": 48,
    "rounding": 40,
    "border": [5, "#303030", 1, "dash", 9],
    "border_position": "center",
    "border_seg_cap": true,
    "padding": [15, 25],
    "background": "#000000",
    "border_hover": [4, "#FF0", 1, "dot", 4, 1],
    "border_click": [4, "#0FF", 1, "dash", 5, 6],
    "margin": 0
  },
  "ComboBox": {
    "width": 200,
    "height": 18,
    "rounding": 65,
    "padding": [15, 25],
    "margin": 0
  },
  "Slider": {
    "width": 250,
    "margin": 0
  },
  "Checkbox": {
    "margin": 0
  },
  "Separator": {
    "space": 6,
    "color": "#333333",
    "margin": 0
  },
  "Column": {
    "gap": 0,
    "padding": 0
  },
  "Row": {
    "gap": 0,
    "padding": 0,
    "align": "center"
  },
  "Tabs": {
    "gap": 4,
    "margin": 0,
    "tab_padding": 10
  },
  "Panel": {
    "background": "#1A1D23",
    "rounding": 8,
    "padding": [5, 10, 15, 5],
    "border": [1, "#333333"]
  },
  "Window": {
    "default_width": 400,
    "default_height": 300,
    "resizable": true,
    "movable": true,
    "collapsible": true,
    "title_bar": true,
    "show_close": true,
    "constrain": true,
    "modal": false,
    "background": "#1E1E24",
    "border": [1, "#33333A"],
    "padding": 8
  },
  "Hyperlink": {
    "color": "#66CCFF",
    "underline": true,
    "margin": 0
  },
  "Grid": {
    "spacing_x": 8,
    "spacing_y": 4
  },
  "ScrollArea": {
    "axis": "vertical"
  },
  "FileDrop": {
    "background": "#1A1D23",
    "rounding": 8,
    "border": [1, "#333333"],

    "highlight_color": "#3366CC44",
    "padding": 16
  },
  "RadioGroup": {
    "margin": 0
  },
  "Spinner": {
    "color": "#66CCFF",
    "size": 24
  },
  "ColorPicker": {
    "width": 160
  },
  "MenuBar": {},
  "MenuItem": {},
  "SubMenu": {},
  "Notifications": {
    "width": 300
  },
  "Tray": {},
  "IconBar": {
    "background": "#1C1C22",
    "border": 0
  },
  "Caption": {
    "color": "#888888",
    "size": 11,
    "margin": 0
  },
  "Indicator": {
    "size": 8
  },
  "StatusBar": {
    "height": 26,
    "background": "#18181D",
    "border": [1, "#2A2A30"],
    "padding": 4
  }
}