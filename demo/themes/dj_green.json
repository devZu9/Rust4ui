{
  "Label": {
    "color": "#E0E0E0",
    "size": 13
  },
  "Button": {
    "background": "#0A1A0A",
    "rounding": 4,
    "min_width": 100,
    "text_color": "#00FF66"
  },
  "TextField": {
    "width": 200,
    "height": 28
  },
  "ComboBox": {
    "width": 200
  },
  "Slider": {
    "width": 250
  },
  "Checkbox": {},
  "Separator": {
    "space": 6,
    "color": "#00FF6622"
  },
  "Column": {
    "gap": 0,
    "padding": 0
  },
  "Row": {
    "gap": 0,
    "padding": 0,
    "align": "center"
  },
  "Tabs": {
    "gap": 4
  },
  "Panel": {
    "background": "#0A0F0A",
    "rounding": 4,
    "padding": 12,
    "border": [1, "#00FF6633"]
  },
  "Window": {
    "default_width": 400,
    "default_height": 300,
    "resizable": true,
    "movable": true,
    "collapsible": true,
    "title_bar": true,
    "show_close": true,
    "constrain": true,
    "modal": false,
    "background": "#0A0F0A",
    "border": [1, "#00FF6633"],
    "padding": 8
  },
  "Hyperlink": {
    "color": "#00FF66",
    "underline": true
  },
  "Grid": {
    "spacing_x": 8,
    "spacing_y": 4
  },
  "ScrollArea": {
    "axis": "vertical"
  },
  "FileDrop": {
    "background": "#0A0F0A",
    "rounding": 4,
    "border": [1, "#00FF6633"],
    "highlight_color": "#00FF6644",
    "padding": 16
  },
  "RadioGroup": {},
  "Spinner": {
    "color": "#00FF66",
    "size": 24
  },
  "ColorPicker": {
    "width": 160
  },
  "MenuBar": {},
  "MenuItem": {},
  "SubMenu": {},
  "Notifications": {
    "width": 300
  },
  "Tray": {},
  "IconBar": {
    "background": "#0A0F0A",
    "border": 0
  },
  "IconButton": {
    "icon_size": 1.2,
    "icon_color": "#00FF66"
  },
  "Caption": {
    "color": "#00AA44",
    "size": 11
  },
  "Indicator": {
    "size": 8
  },
  "StatusBar": {
    "height": 26,
    "background": "#0A0F0A",
    "border": [1, "#00FF6633"],
    "padding": 4
  },
  "Hover": {
    "Button": { "fill_brighten": 0.15, "stroke_brighten": 0.10 },
    "MenuItem": { "fill_brighten": 0.10 },
    "IconButton": { "icon_brighten": 0.25 },
    "Hyperlink": { "underline": true },
    "ComboBox": { "fill_brighten": 0.08 },
    "Checkbox": { "fill_brighten": 0.06 }
  },
  "Focus": {
    "border_color": "#00FF66",
    "border_width": 2
  },
  "Disabled": {
    "opacity": 0.3,
    "fill_desaturate": true
  }
}
